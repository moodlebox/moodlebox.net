{{- $index := slice -}}
{{- range where site.Pages "Type" "in" (slice "kb" "news") -}}
  {{ if ne .Plain "" }}
    {{- if ne .Params.noindex true -}}
      {{- $index = $index | append (
        dict
          "date" (.Date.Format "2006-01-02")
          "url" .RelPermalink
          "title" (.Title | plainify)
          "description" (.Description | plainify)
          "content" (.Content | plainify | replaceRE "\\n+" " ")
        ) -}}
    {{- end -}}
  {{- end -}}
{{- end -}}
{{- $index | jsonify -}}
